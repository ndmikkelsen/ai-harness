{
  "governance": "GSD",
  "source_of_truth": [
    ".rules/",
    ".planning/"
  ],
  "mode": "interactive",
  "granularity": "standard",
  "parallelization": {
    "enabled": true
  },
  "planning": {
    "commit_docs": true
  },
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "auto_advance": false,
    "research_before_questions": false,
    "discuss_mode": "discuss",
    "skip_discuss": false,
    "text_mode": false
  },
  "hooks": {
    "context_warnings": true
  }
}
